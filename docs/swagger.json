{
    "swagger": "2.0",
    "info": {
        "description": "API สำหรับระบบ EazyStore",
        "title": "EazyStore API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/auth/login": {
            "post": {
                "description": "ล็อกอินด้วย Username, Email หรือ เบอร์โทรศัพท์",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "เข้าสู่ระบบ (Login)",
                "parameters": [
                    {
                        "description": "ข้อมูลสำหรับ Login",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.LoginInput"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/auth/register": {
            "post": {
                "description": "ลงทะเบียนผู้ใช้ใหม่เข้าสู่ระบบ",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "สมัครสมาชิก",
                "parameters": [
                    {
                        "description": "ข้อมูลสำหรับสมัครสมาชิก",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.RegisterInput"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "status: success",
                        "schema": {
                            "type": "object"
                        }
                    }
                }
            }
        },
        "/api/createDebtor": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "สร้างลูกหนี้ใหม่ลงในฐานข้อมูล",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Debtor"
                ],
                "summary": "เพิ่มลูกหนี้",
                "parameters": [
                    {
                        "description": "ข้อมูลลูกหนี้",
                        "name": "Debtor",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Debtor"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Debtor"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/createProduct": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "สร้างรายการสินค้าใหม่ลงในฐานข้อมูล",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "เพิ่มสินค้า",
                "parameters": [
                    {
                        "description": "ข้อมูลสินค้า",
                        "name": "product",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Product"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Product"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/createShop": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "สร้างร้านค้าใหม่ลงในฐานข้อมูล",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Shop"
                ],
                "summary": "เพิ่มร้านค้า",
                "parameters": [
                    {
                        "description": "ข้อมูลร้านค้า",
                        "name": "Shop",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Shop"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Shop"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/deleteShop/{shop_id}": {
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "ลบร้านค้าของ User id และ Shop id ที่ส่งเข้ามา",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Shop"
                ],
                "summary": "ลบร้านค้า",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Shop ID",
                        "name": "shop_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Shop not found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/getNullBarcode": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "ดึงรายการสินค้าที่ไม่มีบาร์โค้ดแยกตามร้านค้า",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "ดูสินค้าไม่มีบาร์โค้ด",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "รหัสร้านค้า (Shop ID)",
                        "name": "shop_id",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "รหัสหมวดหมู่สินค้า (Category ID)",
                        "name": "category_id",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Product"
                            }
                        }
                    },
                    "404": {
                        "description": "Product not found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/getShop": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "ดูร้านค้าของ User ที่ Login อยู่ (ดึง ID จาก Token)",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Shop"
                ],
                "summary": "ดูร้านค้า",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Shop"
                            }
                        }
                    },
                    "404": {
                        "description": "Shop not found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/product/search": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "ค้นหาสินค้าด้วย Keyword (รองรับทั้ง Barcode, Product Code และชื่อสินค้า)",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "ค้นหาสินค้า (Search Product)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "คำค้นหา (ระบุ Barcode, รหัส หรือ ชื่อ)",
                        "name": "keyword",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Product"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Product not found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/product/stock": {
            "put": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "บันทึกยอดสต็อกสินค้าล่าสุด",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "อัปเดตสต็อกสินค้า (Update Product Stock)",
                "parameters": [
                    {
                        "description": "ข้อมูลอัปเดตสต็อก",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.UpdateStockRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "message: success",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Invalid input",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Update failed",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/products": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "ดึงข้อมูลสินค้าทั้งหมดที่ผูกกับ shop_id โดยเรียงจากใหม่ไปเก่า",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "ดึงรายการสินค้าทั้งหมดของร้านค้า",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "รหัสร้านค้า (Shop ID)",
                        "name": "shop_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Product"
                            }
                        }
                    },
                    "400": {
                        "description": "กรุณาระบุ shop_id",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "ไม่สามารถดึงข้อมูลสินค้าได้",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/products/{id}": {
            "put": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "อัปเดตเฉพาะฟิลด์ที่ส่งมา และบันทึกประวัติราคาอัตโนมัติ (Manual Log)",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Product"
                ],
                "summary": "แก้ไขข้อมูลสินค้า (Partial Update)",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Product ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "ข้อมูลสินค้า (ส่งเฉพาะตัวที่แก้)",
                        "name": "product",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Product"
                        }
                    }
                }
            }
        },
        "/api/updateShop/{shop_id}": {
            "put": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "แก้ไขเฉพาะข้อมูลที่ส่งมา (Field ไหนไม่ส่งมา จะใช้ค่าเดิม)",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Shop"
                ],
                "summary": "แก้ไขข้อมูลร้านค้า",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Shop ID",
                        "name": "shop_id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "ข้อมูลที่ต้องการแก้",
                        "name": "shop",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.UpdateShopInput"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "models.Category": {
            "type": "object",
            "properties": {
                "category_id": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "models.Debtor": {
            "type": "object",
            "properties": {
                "address": {
                    "type": "string",
                    "example": "123 ถ.สุขุมวิท แขวงคลองเตย เขตคลองเตย กทม 10110"
                },
                "credit_limit": {
                    "type": "integer",
                    "example": 2000
                },
                "current_debt": {
                    "type": "number",
                    "example": 0
                },
                "debtor_id": {
                    "type": "integer"
                },
                "img_debtor": {
                    "type": "string",
                    "example": "https://image.url/debtor.jpg"
                },
                "name": {
                    "type": "string",
                    "example": "ป้าเพ็ญ"
                },
                "phone": {
                    "type": "string",
                    "example": "0654891234"
                }
            }
        },
        "models.LoginInput": {
            "type": "object",
            "required": [
                "password",
                "username"
            ],
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "description": "รับค่ามาเป็น \"username\" แต่เราจะเอาไปเช็คว่าเป็น Email หรือ เบอร์โทร ใน Controller",
                    "type": "string"
                }
            }
        },
        "models.Product": {
            "type": "object",
            "required": [
                "category_id",
                "cost_price",
                "img_product",
                "name",
                "sell_price",
                "shop_id",
                "unit"
            ],
            "properties": {
                "barcode": {
                    "type": "string",
                    "example": "885123456789"
                },
                "category": {
                    "$ref": "#/definitions/models.Category"
                },
                "category_id": {
                    "type": "integer",
                    "example": 2
                },
                "cost_price": {
                    "type": "number",
                    "example": 10.5
                },
                "img_product": {
                    "type": "string",
                    "example": "https://image.url/cola.jpg"
                },
                "name": {
                    "type": "string",
                    "example": "น้ำอัดลม โคล่า"
                },
                "product_code": {
                    "type": "string"
                },
                "product_id": {
                    "type": "integer"
                },
                "sell_price": {
                    "type": "number",
                    "example": 15
                },
                "shop_id": {
                    "type": "integer",
                    "example": 1
                },
                "status": {
                    "type": "boolean",
                    "example": true
                },
                "stock": {
                    "description": "gte=0 คือ มากกว่าหรือเท่ากับ 0",
                    "type": "integer",
                    "minimum": 0,
                    "example": 100
                },
                "unit": {
                    "type": "string",
                    "example": "ขวด"
                }
            }
        },
        "models.RegisterInput": {
            "type": "object",
            "required": [
                "email",
                "password",
                "phone",
                "username"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string",
                    "example": "123456"
                },
                "phone": {
                    "type": "string"
                },
                "username": {
                    "type": "string",
                    "example": "poder"
                }
            }
        },
        "models.Shop": {
            "type": "object",
            "required": [
                "address",
                "name",
                "phone",
                "pin_code",
                "user_id"
            ],
            "properties": {
                "address": {
                    "type": "string",
                    "example": "123 ถ.สุขุมวิท แขวงคลองเตย เขตคลองเตย กทม 10110"
                },
                "img_qrcode": {
                    "type": "string",
                    "example": "https://image.url/qrcode.jpg"
                },
                "img_shop": {
                    "type": "string",
                    "example": "https://image.url/homeshop.jpg"
                },
                "name": {
                    "type": "string",
                    "example": "จันทร์เพ็ญ"
                },
                "phone": {
                    "type": "string",
                    "example": "0985490445"
                },
                "pin_code": {
                    "type": "string",
                    "example": "191047"
                },
                "shop_id": {
                    "type": "integer"
                },
                "user_id": {
                    "type": "integer",
                    "example": 1
                }
            }
        },
        "models.UpdateShopInput": {
            "type": "object",
            "properties": {
                "address": {
                    "type": "string",
                    "example": "555 ถ.ลาดพร้าว"
                },
                "img_qrcode": {
                    "type": "string",
                    "example": "https://image.url/new_qrcode.jpg"
                },
                "img_shop": {
                    "type": "string",
                    "example": "https://image.url/new_shop.jpg"
                },
                "name": {
                    "type": "string",
                    "example": "ร้านจันทร์เพ็ญ (แก้ไข)"
                },
                "phone": {
                    "type": "string",
                    "example": "0899998888"
                },
                "pin_code": {
                    "type": "string",
                    "example": "654321"
                }
            }
        },
        "models.UpdateStockRequest": {
            "type": "object",
            "required": [
                "product_id",
                "stock"
            ],
            "properties": {
                "product_id": {
                    "type": "integer"
                },
                "stock": {
                    "type": "integer"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}